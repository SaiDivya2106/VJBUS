# Backend Environment Configuration
NODE_ENV=pro
ENVIRONMENT=pro
PORT=6203

# JWT Secret (must match auth-server.js)
JWT_SECRET=your_secret_key

# MongoDB
MONGO_URI=your_mongo_uri_here

# SSO Configuration
AUTH_SERVER_URL_LOCAL=http://localhost:2999
AUTH_SERVER_URL_DEV=https://dev-auth.vjstartup.com
AUTH_SERVER_URL_PRO=https://authv2.vjstartup.com
APP_NAME=keys

# Client URLs
CLIENT_URL_LOCAL=http://localhost:3203
CLIENT_URL_DEV=https://dev-keys.vjstartup.com
CLIENT_URL_PRO=https://keys.vjstartup.com

# Backend URLs
BACKEND_URL_LOCAL=http://localhost:6203
BACKEND_URL_DEV=https://dev-keys.vjstartup.com/be
BACKEND_URL_PRO=https://keys.vjstartup.com/be

# Google OAuth
GOOGLE_CLIENT_ID=522460567146-ubk3ojomopil8f68hl73jt1pj0jbbm68.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_FROM=noreply@vnrvjiet.in
EMAIL_FROM_NAME=VNR Keys
