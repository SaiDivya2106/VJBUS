### Valid IT complaint (includes required IT fields)
POST http://localhost:6101/user-api/add-complaint
Content-Type: application/json
# Replace the Authorization value with a valid token if your server enforces authentication
Authorization: Bearer <YOUR_JWT_TOKEN_HERE>

{
    "complaint_id": "IT-2001",
    "title": "Slow WiFi in Lab B",
    "description": "Internet is very slow and intermittent in Lab B since morning.",
    "category": "IT and Networking",
    "user_id": "student1@example.com",
    "room_number": "Lab-B",
    "internet_speed": "0.2 Mbps",
    "mobile_number": "9876543210",
    "issue_duration": "3 hours"
}

### Invalid IT complaint (missing IT-specific fields -> should return 400)
POST http://localhost:6101/user-api/add-complaint
Content-Type: application/json
Authorization: Bearer <YOUR_JWT_TOKEN_HERE>

{
    "complaint_id": "IT-2002",
    "title": "No network access",
    "description": "Can't access the internet from my workstation.",
    "category": "IT and Networking",
    "user_id": "student2@example.com"
}
